{
  "manifest_version": 3,
  "name": "Bionluk Alici Istegi Bildirici",
  "version": "2.0",
  "description": "Bionluk.com alici istekleri sayfasini izler, yeni istek geldiginde bildirim gonderir. Anahtar kelime ve butce filtresi destekler.",
  "permissions": [
    "notifications",
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.bionluk.com/*",
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.bionluk.com/panel/alici-istekleri",
        "*://bionluk.com/panel/alici-istekleri",
        "*://www.bionluk.com/panel/alici-istekleri/",
        "*://bionluk.com/panel/alici-istekleri/"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sound/notification.mp3",
        "offscreen.html",
        "images/icon16.png",
        "images/icon48.png",
        "images/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
